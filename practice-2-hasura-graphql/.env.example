# Postgres Connection
DATABASE_URL=postgres://boltline:boltline@localhost:5432/boltline_dev
POSTGRES_USER=boltline
POSTGRES_PASSWORD=boltline
POSTGRES_DB=boltline_dev

# Hasura
HASURA_GRAPHQL_DATABASE_URL=postgres://boltline:boltline@localhost:5432/boltline_dev
HASURA_GRAPHQL_ADMIN_SECRET=myadminsecret
HASURA_GRAPHQL_ENDPOINT=http://localhost:8080
HASURA_GRAPHQL_ENABLE_CONSOLE=true
HASURA_GRAPHQL_DEV_MODE=true

# Action Webhook
ACTION_WEBHOOK_PORT=3001
ACTION_WEBHOOK_SECRET=webhook-secret-12345
ACTION_WEBHOOK_URL=http://localhost:3001
