{
  "name": "@boltline/practice-temporal-kafka",
  "version": "1.0.0",
  "private": true,
  "main": "dist/starter.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "dev": "tsx watch src/temporal/worker.ts",
    "start:worker": "node dist/temporal/worker.js",
