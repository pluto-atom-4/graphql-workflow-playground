    "kafkajs": "^2.2.4",
    "nanoid": "^4.0.2"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.10.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "jest": "workspace:*",
    "ts-jest": "workspace:*",
    "tsx": "^4.7.0",
    "typescript": "workspace:*"
