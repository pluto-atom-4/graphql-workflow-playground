{
  "name": "graphql-workflow-playground",
  "version": "1.0.0",
  "private": true,
  "description": "Interview preparation playground for Stoke Space Boltline — mastering Temporal, Kafka, Hasura, and Next.js",
  "scripts": {
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @boltline/practice-nextjs-graphql e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,gql}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,gql}\" --ignore-path .gitignore",
    "dev:p1": "pnpm --filter @boltline/practice-temporal-kafka dev",
    "dev:p2": "pnpm --filter @boltline/practice-hasura-graphql dev",
    "dev:p3": "pnpm --filter @boltline/practice-nextjs-graphql dev",
    "codegen": "pnpm --filter @boltline/graphql-types codegen",
    "infra:up": "docker compose -f infra/docker/docker-compose.shared.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.shared.yml down",
    "infra:logs": "docker compose -f infra/docker/docker-compose.shared.yml logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.22.0",
    "@typescript-eslint/parser": "^7.22.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.0"
}
